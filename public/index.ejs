   <script>
      // Función para detectar parámetros en la URL
      function getQueryParam(param) {
         const urlParams = new URLSearchParams(window.location.search);
         return urlParams.get(param);
      }

      // Al cargar la página, verifica el parámetro "alert"
      window.onload = function () {
         const alertParam = getQueryParam('alert');
         if (alertParam === 'not_authenticated') {
            alert('Por favor, regístrate o inicia sesión para acceder.');
         }
      };
